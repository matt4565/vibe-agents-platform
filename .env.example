# LLM Configuration (OpenAI-compatible)
OPENAI_API_KEY=sk-your-key-here-or-groq-key
OPENAI_BASE_URL=https://api.openai.com/v1   # Change to https://api.groq.com/openai/v1 for Groq, or xAI endpoint if compatible

# Optional: Default model
DEFAULT_MODEL=gpt-4o-mini
# For best quality use gpt-4o or claude-3-5-sonnet-20241022 (if using compatible proxy)
